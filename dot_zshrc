export ZSH="$HOME/.oh-my-zsh"

ZSH_THEME="robbyrussell"

plugins=(git zsh-autosuggestions docker dotenv)

source $ZSH/oh-my-zsh.sh

# Use the pure shell
fpath+=$HOME/.zsh/pure
autoload -U promptinit; promptinit
prompt pure

# Add the pipx location to the path
export PATH="$PATH:/Users/jules/.local/bin"
export PATH="/opt/homebrew/opt/node@22/bin:$PATH"

# Create an alias for the correct python version
alias python3=python3.13
alias pip3=pip3.13
alias python=python3.13
alias pip=pip3.13

export LDFLAGS="-L/opt/homebrew/opt/freetds/lib -L/opt/homebrew/opt/openssl@3/lib"
export CFLAGS="-I/opt/homebrew/opt/freetds/include"
export CPPFLAGS="-I/opt/homebrew/opt/openssl@3/include"

# Setup zoxide and add aliases to be backwards compatible
eval "$(zoxide init zsh)"

alias cd=z
alias cdi=zi

# Apply chezmoi without running scripts
alias cm='chezmoi apply --exclude=scripts'

# Stop all docker containers
alias dstop='docker stop $(docker ps -a -q)'

# Auto-start tmux on new shell
if [ -z "$TMUX" ] && [ "$TERM_PROGRAM" != "vscode" ]; then
  tmux attach -t default 2>/dev/null || tmux new -s default
fi

# Enable autocompletions for Docker
fpath=(/Users/jules/.docker/completions $fpath)
autoload -Uz compinit
compinit
